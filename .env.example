# mock | startup | enrol (see docs/Framework.md)
MODE=mock
DOMAIN=biab.local
HUMAN=founder

# Central listens on 8080 inside the container; host mapping via CEO_CENTRAL_PORT in compose.
CEO_CENTRAL_PORT=8080

# NerveCentre (Marvin or VIP) — used for /api/nervecentre/probe and future hooks.
# Example on LAN: http://marvin.lan  or  http://192.168.1.10
NERVECENTRE_PUBLIC_ORIGIN=http://localhost

# Path appended to origin for probe (default /).
# NERVECENTRE_PING_PATH=/

# Optional shared secret for POST /api/hooks/nervecentre (header X-Nervecentre-Secret).
# NERVECENTRE_WEBHOOK_SECRET=

# Dev: FLASK_DEBUG=1
