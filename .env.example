# mock | startup | enrol (see docs/Framework.md)
MODE=mock
DOMAIN=biab.local
HUMAN=founder

# Central API
CEO_CENTRAL_PORT=8080

# Mail server
MAIL_SMTP_PORT=25
MAIL_IMAP_PORT=143
MAIL_SUBMISSION_PORT=587
CEO_MAIL_PASS=ceo123

# Roundcube webmail (http://localhost:8081)
ROUNDCUBE_PORT=8081
ROUNDCUBE_DES_KEY=                             # generate: openssl rand -base64 24
ROUNDCUBE_DB_ROOT_PASS=roundcube_root
ROUNDCUBE_DB_NAME=roundcube
ROUNDCUBE_DB_USER=roundcube
ROUNDCUBE_DB_PASS=roundcube_pass

# NerveCentre (Marvin or VIP) — probe target behind reverse proxy
NERVECENTRE_PUBLIC_ORIGIN=http://localhost
# NERVECENTRE_PING_PATH=/
# NERVECENTRE_WEBHOOK_SECRET=

# Dev
# FLASK_DEBUG=1

# Cloudflare
# CLOUDFLARE_API_TOKEN=
# CF_TUNNEL_TOKEN=                          # generate: cloudflared tunnel token <name>

# Cloudflare Email Routing — shared secret between Worker and central
# INGEST_SECRET=changeme

# Opencode worker (host-side, outside Docker)
# CENTRAL_URL=http://127.0.0.1:8080
# WORKER_ID=opencode-worker
# OPENCODE_MODEL=opencode/big-pickle
# POLL_INTERVAL=3
# OPENCODE_TIMEOUT=120
